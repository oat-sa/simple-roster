<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity repository-class="OAT\SimpleRoster\Repository\RosteringImportRepository" name="OAT\SimpleRoster\Entity\RosteringImport" table="rostering_import">
        <id name="id" type="integer" column="id">
            <generator strategy="SEQUENCE"/>
            <sequence-generator sequence-name="rostering_import_id_seq" allocation-size="1" initial-value="1"/>
        </id>
        <field name="referenceId" column="reference_id" length="36" unique="true"/>
        <field name="status" column="status" length="32"/>
        <field name="errorMessage" type="text" column="error_message" nullable="true"/>
        <field name="attempts" type="integer" column="attempts" nullable="false">
            <options>
                <option name="default">0</option>
            </options>
        </field>
        <field name="totalRows" type="integer" column="total_rows" nullable="true"/>
        <field name="processedRows" type="integer" column="processed_rows" nullable="true"/>
        <field name="failedRows" type="integer" column="failed_rows" nullable="true"/>
        <field name="startedAt" type="datetime" column="started_at" nullable="true"/>
        <field name="finishedAt" type="datetime" column="finished_at" nullable="true"/>
    </entity>
</doctrine-mapping>
